# ================================================================
#  FOREX AI BOT — TEMPLATE CONFIGURAZIONE
#  Copia questo file in .env e compila i valori
#  comando: cp .env.example .env
# ================================================================

# ── Claude API ──────────────────────────────────────────────────
# Ottieni la chiave su: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-

# Modello: haiku = ~$9-11/mese | sonnet = ~$16-20/mese
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── MetaTrader 5 ─────────────────────────────────────────────────
# Trovi questi dati nell'email di registrazione del broker demo
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# Broker consigliati (conto demo gratuito):
#   IC Markets EU  → MT5_SERVER=ICMarketsSC-Demo   (icmarketseu.com)
#   IC Markets     → MT5_SERVER=ICMarkets-Demo      (icmarkets.com)
#   Pepperstone    → MT5_SERVER=Pepperstone-Demo    (pepperstone.com)
#   MetaQuotes     → MT5_SERVER=MetaQuotes-Demo     (demo generico MT5)

# ── Simbolo ──────────────────────────────────────────────────────
# Cambia questi 4 valori insieme per tradare altri asset
SYMBOL=EURUSD
SYMBOL_BASE=EUR
SYMBOL_QUOTE=USD
CENTRAL_BANK_BASE=BCE (Banca Centrale Europea)
CENTRAL_BANK_QUOTE=Federal Reserve (Fed)

# Altri asset — decommenta e sostituisci i 4 valori sopra:
#
# GBP/USD:
#   SYMBOL=GBPUSD | SYMBOL_BASE=GBP | SYMBOL_QUOTE=USD
#   CENTRAL_BANK_BASE=Bank of England | CENTRAL_BANK_QUOTE=Federal Reserve
#
# USD/JPY:
#   SYMBOL=USDJPY | SYMBOL_BASE=USD | SYMBOL_QUOTE=JPY
#   CENTRAL_BANK_BASE=Federal Reserve | CENTRAL_BANK_QUOTE=Bank of Japan
#
# Oro:
#   SYMBOL=XAUUSD | SYMBOL_BASE=Gold | SYMBOL_QUOTE=USD
#   CENTRAL_BANK_BASE= | CENTRAL_BANK_QUOTE=Federal Reserve

# ── Modalità ─────────────────────────────────────────────────────
# true  → analizza ma NON apre ordini reali (consigliato per iniziare)
# false → trading live sul conto demo
DRY_RUN=true

# ── Opzionali (hanno già default sensati) ────────────────────────
# TIMEFRAME=H1
# REQUIRE_H4_CONFIRM=true
# DASHBOARD_PORT=8000

# USE_MOCK=false
# true  → usa sempre il broker simulato, nessuna connessione MT5
#          (utile su Mac/Linux o per testare senza MT5 aperto)
# false → usa MT5 reale se disponibile (default)
# Nota: python bot.py --dry forza il mock automaticamente senza
#       bisogno di impostare questa variabile

# MOCK_DATA_FILE=
# Percorso a un CSV con dati storici reali da usare in dry-run/mock.
# Se vuoto → genera candele sintetiche random (default).
# Come scaricare dati storici gratis:
#   1. Apri MetaTrader 5 → simbolo EURUSD → H1
#   2. File → Esporta → CSV (formato: Date,Time,Open,High,Low,Close,Volume)
#   3. Oppure da Dukascopy: https://www.dukascopy.com/swiss/english/marketwatch/historical/
# Esempio: MOCK_DATA_FILE=data/EURUSD_H1_2024.csv
